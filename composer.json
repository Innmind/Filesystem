{
    "name": "innmind/filesystem",
    "type": "library",
    "description": "Filesystem abstraction layer",
    "keywords": ["filesystem"],
    "homepage": "http://github.com/Innmind/filesystem",
    "license": "MIT",
    "authors": [
        {
            "name": "Baptiste Langlade",
            "email": "baptiste.langlade@hey.com"
        }
    ],
    "support": {
        "issues": "http://github.com/Innmind/filesystem/issues"
    },
    "require": {
        "php": "~8.4",
        "innmind/immutable": "~6.0",
        "innmind/media-type": "~3.0",
        "innmind/url": "~5.0",
        "psr/log": "~3.0",
        "innmind/io": "~4.0",
        "innmind/validation": "~3.0"
    },
    "autoload": {
        "psr-4": {
            "Innmind\\Filesystem\\": "src/",
            "Fixtures\\Innmind\\Filesystem\\": "fixtures/",
            "Properties\\Innmind\\Filesystem\\": "properties/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Innmind\\Filesystem\\": "tests/"
        }
    },
    "require-dev": {
        "innmind/static-analysis": "~1.3",
        "innmind/black-box": "~6.5",
        "innmind/coding-standard": "~2.0",
        "symfony/filesystem": "~6.0|~7.0|~8.0",
        "ramsey/uuid": "^4.6"
    },
    "conflict": {
        "innmind/black-box": "<6.0|~7.0"
    },
    "suggest": {
        "innmind/black-box": "For property based testing"
    },
    "provide": {
        "innmind/black-box-sets": "6.0"
    }
}
